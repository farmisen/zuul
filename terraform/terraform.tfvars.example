# GCP project where zuul secrets will be stored (required)
project_id = "my-gcp-project-123"

# Zuul environment names (optional, defaults to ["production", "staging", "dev"])
environments = ["production", "staging", "dev"]

# Optional descriptions for environments
environment_descriptions = {
  production = "Live production environment"
  staging    = "Pre-production staging"
  dev        = "Local development"
}

# IAM members and their access levels (required)
# Format: "user:email", "serviceAccount:email", or "group:email"
# Roles:
#   admin — full secretmanager.admin (project-wide, no environments needed)
#   write — read + write secrets in specified environments
#   read  — read-only access to secrets in specified environments
members = {
  "user:ops@company.com" = {
    role = "admin"
  }
  "user:alice@company.com" = {
    role         = "write"
    environments = ["dev", "staging"]
  }
  "user:bob@company.com" = {
    role         = "read"
    environments = ["dev"]
  }
}

# Create per-developer service accounts mirroring IAM access above (optional)
# Useful when developers have multiple GCP accounts on one machine.
# Each "user:" member gets a zuul-dev-{name} SA with the same permissions.
# Developers download their key from the GCP Console → IAM → Service Accounts.
create_developer_sas = false

# CI/CD service accounts to create (optional)
# Keys are SA names (will be prefixed with "zuul-"), values are the zuul
# environment they can access. Multiple SAs can target the same environment.
service_accounts = {
  "staging-ci"        = "staging"
  "production-deploy" = "production"
}
